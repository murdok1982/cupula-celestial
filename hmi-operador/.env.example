# =====================================================================
# Cupula Celestial - HMI Operador
# Copiar a .env.local y rellenar. NUNCA commitear secrets.
# =====================================================================

# Base URL del hmi-gateway (Rust). En produccion HTTPS obligatorio.
VITE_API_BASE_URL=http://127.0.0.1:8080

# WebSocket endpoint del hmi-gateway
VITE_WS_URL=ws://127.0.0.1:8080/ws

# audit-log service
VITE_AUDIT_URL=http://127.0.0.1:9300

# swarm-controller
VITE_SWARM_URL=http://127.0.0.1:9200

# decision-engine
VITE_DECISION_URL=http://127.0.0.1:8002

# Cesium ion token (opcional, vacio = solo terreno offline)
VITE_CESIUM_ION_TOKEN=

# Activar mocks MSW (true en dev local sin backend)
VITE_USE_MOCKS=true

# Idioma por defecto
VITE_DEFAULT_LOCALE=es

# Auto-logout inactividad en milisegundos (10 min)
VITE_IDLE_TIMEOUT_MS=600000

# Timeout dialogo autorizacion engagement (30s segun MIL-STD-1472)
VITE_AUTH_DIALOG_TIMEOUT_MS=30000
