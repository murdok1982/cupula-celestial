# Template OpenSSL para cert de servicio mTLS Cúpula Celestial.
# Sustitución antes de uso:
#   __SERVICE__ → nombre del servicio (DNS interno y CN)
#
# Genera certificados con:
#   - extendedKeyUsage = serverAuth + clientAuth (mTLS bidireccional)
#   - SAN = DNS:__SERVICE__, DNS:localhost, IP:127.0.0.1

[ req ]
default_bits        = 4096
default_md          = sha384
distinguished_name  = req_distinguished_name
req_extensions      = v3_req
prompt              = no
encrypt_key         = no

[ req_distinguished_name ]
C   = ES
ST  = Madrid
O   = Cupula Celestial PoC
OU  = Cybersecurity
CN  = __SERVICE__

[ v3_req ]
basicConstraints       = CA:FALSE
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = serverAuth, clientAuth
subjectAltName         = @alt_names

[ alt_names ]
DNS.1 = __SERVICE__
DNS.2 = localhost
DNS.3 = __SERVICE__.cupula
IP.1  = 127.0.0.1
